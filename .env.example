# Service Configuration
PORT=3009
SERVICE_NAME=ai-agents
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/iconradar

# Redis
REDIS_URL=redis://localhost:6379

# Service Discovery
# Athlete and Brand routes are handled by the main backend API
AUTH_SERVICE_URL=https://api.radar.passbook.vc
EXTERNAL_APIS_URL=https://icon-radar-external-apis.up.railway.app
ATHLETE_SERVICE_URL=https://api.radar.passbook.vc
BRAND_SERVICE_URL=https://api.radar.passbook.vc

# Security
JWT_SECRET=your-jwt-secret-key
SERVICE_API_KEY=your-service-api-key

# AI Provider Configuration (Open-Source & Cost-Effective)
# Primary provider (cheapest first)
AI_PROVIDER_PRIMARY=glm
AI_PROVIDER_FALLBACK=qwen

# GLM (Zhipu AI - ChatGLM) - Extremely cheap and fast
# Sign up: https://open.bigmodel.cn/
GLM_API_KEY=your-glm-api-key
GLM_MODEL=glm-4-flash
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Deepseek - OpenAI-compatible, very cost-effective
# Sign up: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Alibaba Qwen (DashScope) - Good for Chinese/multilingual
# Sign up: https://dashscope.aliyun.com/
QWEN_API_KEY=your-qwen-api-key
QWEN_MODEL=qwen-turbo
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# AI Client Settings
AI_TIMEOUT=60000
AI_MAX_RETRIES=3

# Meta API (for social data collection)
META_API_KEY=...
META_APP_ID=...

# External APIs
CRUNCHBASE_API_KEY=...
LINKEDIN_ACCESS_TOKEN=...
META_ACCESS_TOKEN=...
TIKTOK_ACCESS_TOKEN=...
SEMRUSH_API_KEY=...

# Langflow Integration
LANGFLOW_URL=http://localhost:7860
LANGFLOW_API_KEY=...
LANGFLOW_TIMEOUT=30000

# Agent Configuration
BRAND_DISCOVERY_MAX_RESULTS=20
VERIFICATION_MIN_CONFIDENCE=60
METRICS_COLLECTION_LOOKBACK_DAYS=30
SCORING_UPDATE_FREQUENCY_HOURS=6

# Logging
LOG_LEVEL=info
