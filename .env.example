# Service Configuration
PORT=3009
SERVICE_NAME=ai-agents
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/iconradar

# Redis
REDIS_URL=redis://localhost:6379

# Service Discovery
AUTH_SERVICE_URL=http://localhost:3001
EXTERNAL_APIS_URL=http://localhost:3008
ATHLETE_SERVICE_URL=http://localhost:3002
BRAND_SERVICE_URL=http://localhost:3003

# Security
JWT_SECRET=your-jwt-secret-key
SERVICE_API_KEY=your-service-api-key

# AI Provider API Keys
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...
CLAUDE_API_KEY=...
META_API_KEY=...
META_APP_ID=...

# External APIs
CRUNCHBASE_API_KEY=...
LINKEDIN_ACCESS_TOKEN=...
META_ACCESS_TOKEN=...
TIKTOK_ACCESS_TOKEN=...
SEMRUSH_API_KEY=...

# Langflow Integration
LANGFLOW_URL=http://localhost:7860
LANGFLOW_API_KEY=...
LANGFLOW_TIMEOUT=30000

# Agent Configuration
BRAND_DISCOVERY_MAX_RESULTS=20
VERIFICATION_MIN_CONFIDENCE=60
METRICS_COLLECTION_LOOKBACK_DAYS=30
SCORING_UPDATE_FREQUENCY_HOURS=6

# Logging
LOG_LEVEL=info
